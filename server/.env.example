# Lexora - Server Environment Variables
# Copy this file to .env and fill in your values

# Server Configuration
PORT=3001
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=lexora

# Client Origin (for CORS)
CLIENT_ORIGIN=http://localhost:5173

# Logging
LOG_LEVEL=info


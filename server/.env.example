# ── Lexora Server — environment variables ──────────────────
# Copy this file to .env and fill in your values

# Port the Express server listens on
PORT=3001

# URL of the local olmOCR Python server (must be running separately)
OCR_SERVER_URL=http://localhost:5001

# Allowed CORS origin (your Vite dev server)
CLIENT_ORIGIN=http://localhost:5173

# Google Books API key (optional — improves rate limits)
# Get one at: https://console.cloud.google.com/apis/library/books.googleapis.com
GOOGLE_BOOKS_API_KEY=AIzaSyDirvHmBzz7mRw1LVOf7U2WgVV7K2iX_GM

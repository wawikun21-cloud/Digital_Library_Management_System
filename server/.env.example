# ─────────────────────────────────────────────────────────
#  Lexora Backend — Environment Variables
#  Copy this file to .env and fill in your real values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────

# Absolute path to your Google Cloud Service Account JSON file.
# Keep this file OUTSIDE the public/ directory.
# Example (Windows): C:\keys\lexora-vision-sa.json
# Example (Linux/Mac): /etc/secrets/lexora-vision-sa.json
GOOGLE_APPLICATION_CREDENTIALS=C:\keys\lexora-vision-sa.json

# Port the Express server listens on
PORT=3001

# Frontend origin for CORS (Vite default)
CLIENT_ORIGIN=http://localhost:5173

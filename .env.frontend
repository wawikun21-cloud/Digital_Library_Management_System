# Frontend environment variables (Vite)
# Prefix all variables with VITE_ to expose them to the browser bundle.
# This file is safe to commit — it contains NO secrets.

# When vite.config.js proxy is active (development), this can stay empty
# and the proxy will forward /api/* to port 3001 automatically.
# For production builds pointing to a deployed server, set the full URL:
# VITE_API_URL=https://your-api-server.com
VITE_API_URL=
